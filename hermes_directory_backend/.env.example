# Django settings module.
# Dev default in manage.py: base_hermes.settings.dev
# For production use: base_hermes.settings.prod
DJANGO_SETTINGS_MODULE=base_hermes.settings.dev

# Security
SECRET_KEY=change-me
DEBUG=True

# Hosts and CORS/CSRF (comma-separated)
ALLOWED_HOSTS=127.0.0.1,localhost,192.168.100.30
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database (production profile)
USE_POSTGRES=False
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60

# Production security defaults (used by base_hermes.settings.prod)
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SECURE_CONTENT_TYPE_NOSNIFF=True
X_FRAME_OPTIONS=DENY
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
USE_X_FORWARDED_PROTO=False
